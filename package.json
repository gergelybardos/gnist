{
  "name": "@gergely-bardos/gnist",
  "version": "0.0.0",
  "description": "Lightweight, renderer-agnostic particle simulation engine built with vanilla JavaScript for real-time visual effects",
  "keywords": [
    "collision-detection",
    "engine",
    "esm",
    "lightweight",
    "particle",
    "particle-engine",
    "particle-physics",
    "particle-system",
    "physics",
    "simulation",
    "vanilla-js"
  ],
  "author": "Gergely Bárdos (https://github.com/gergelybardos)",
  "license": "MIT",
  "homepage": "https://github.com/gergelybardos/gnist#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gergelybardos/gnist.git"
  },
  "type": "module",
  "exports": {
    ".": {
      "import": "./src/index.js",
      "types": "./types/index.d.ts"
    }
  },
  "sideEffects": false,
  "files": [
    "src",
    "types"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=9.6.4"
  },
  "scripts": {
    "dev": "vite",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "types": "tsc",
    "doc:api": "jsdoc -c jsdoc.json -R docs/src/api/homepage.md",
    "doc:deploy": "npm run doc:api && gh-pages -d docs/site",
    "version:changelog": "conventional-changelog -p conventionalcommits -i CHANGELOG.md -s",
    "prepublishOnly": "npm run lint && npm run types"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "conventional-changelog-cli": "^5.0.0",
    "conventional-changelog-conventionalcommits": "^9.3.1",
    "docdash": "^2.0.2",
    "eslint": "^10.5.0",
    "eslint-plugin-jsdoc": "^63.0.8",
    "gh-pages": "^6.3.0",
    "globals": "^17.6.0",
    "jsdoc": "^4.0.5",
    "typescript": "^6.0.3",
    "vite": "^8.0.16"
  }
}
